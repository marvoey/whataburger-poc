---
import Layout from '@layouts/Layout.astro';
import Page from '@components/Page.astro';
import CategoryGrid from '@components/CategoryGrid.astro';
import CustomizationGroups from '@components/CustomizationGroups.astro';
import { GraphClient } from '@optimizely/cms-sdk';

const { searchParams } = Astro.url;
const key = searchParams.get('key') ?? '';
const ver = searchParams.get('ver') ?? '';
const loc = searchParams.get('loc') ?? '';
const ctx = searchParams.get('ctx') ?? '';
const preview_token = searchParams.get('preview_token') ?? '';

// --- Domain resolution ---
const CMS_ORIGIN = import.meta.env.CMS_ORIGIN as string | undefined;
const DOMAIN_ALIASES = import.meta.env.DOMAIN_ALIASES as string | undefined;
const aliases = new Set((DOMAIN_ALIASES ?? '').split(',').map((s) => s.trim()).filter(Boolean));
const base = CMS_ORIGIN && aliases.has(Astro.url.host) ? CMS_ORIGIN : Astro.url.origin;

const cmsClient = new GraphClient(import.meta.env.OPTIMIZELY_GRAPH_SINGLE_KEY, {
  graphUrl: `${import.meta.env.OPTIMIZELY_GRAPH_GATEWAY}/content/v2`,
});

const token = preview_token || undefined;

// const previewData = await cmsClient.getPreviewContent({ key, ver,loc, ctx, preview_token});

const result = key ? await cmsClient.request(`
  query PreviewByKey($key: String!, $ver: String, $loc: [Locales]) {
    _Content(
      where: {
        _metadata: {
          key: { eq: $key }
          version: { eq: $ver }
        }
      }
      locale: $loc
      limit: 1
    ) {
      items {
        _metadata {
          key
          displayName
          url { default base hierarchical }
          version
          locale
          types
        }
        ... on WhataItemPage {
          CustomOptions {
            ... on WhataCustomOptionsGroup {
              _metadata { displayName }
              chooseOne
              Options {
                ... on WhataOption {
                  _metadata { displayName }
                  Calories
                  addedCost
                  Quantity
                }
              }
            }
          }
        }
      }
    }
  }
`, { key, ver: ver || null, loc: loc ? [loc] : null }, preview_token) : null;

const page = result?._Content?.items?.[0];
const types: string[] = page?._metadata?.types ?? [];
const pageType = ['WhataMenuPage', 'WhataCategoryPage', 'WhataItemPage', 'BlankExperience']
  .find((t) => types.includes(t));

const pageHierarchical = page?._metadata?.url?.hierarchical;

type PageItem = { _metadata?: { displayName?: string; url?: { default?: string; hierarchical?: string } } };

const childrenResult = (pageType === 'WhataMenuPage' || pageType === 'WhataCategoryPage' || pageType === 'BlankExperience') && pageHierarchical
  ? await cmsClient.request(`
    query PreviewChildren($base: String!, $hierarchical: String!) {
      _Page(
        where: {
          _metadata: {
            url: {
              base: { eq: $base }
              hierarchical: {
                startsWith: $hierarchical,
                notEq: $hierarchical
              }
            }
          }
        }
        limit: 100
      ) {
        total
        items {
          _metadata {
            displayName
            url { default hierarchical }
          }
        }
      }
    }
  `, { base: base, hierarchical: pageHierarchical }, preview_token)
  : null;

const parentDepth = (pageHierarchical?.match(/\//g) ?? []).length;
const children = ((childrenResult?._Page?.items ?? []) as PageItem[]).filter((item) => {
  const path = item._metadata?.url?.hierarchical ?? '';
  return (path.match(/\//g) ?? []).length === parentDepth + 1;
});

const childItems = children.map((item) => ({
  name: item._metadata?.displayName ?? '',
  slug: item._metadata?.url?.default,
}));

const title = page?._metadata?.displayName ?? '';
---

<Layout>
  {pageType === 'WhataMenuPage' && (
    <Page title={title} dividerLabel="Categories" backHref="/">
      <CategoryGrid items={childItems} />
    </Page>
  )}

  {pageType === 'WhataCategoryPage' && (
    <Page title={title} dividerLabel="Items" backHref="/">
      <CategoryGrid items={childItems} />
    </Page>
  )}

  {pageType === 'WhataItemPage' && (
    <Page title={title} dividerLabel="Customize" backHref="/">
      <CustomizationGroups groups={page?.CustomOptions ?? []} />
    </Page>
  )}

  {pageType === 'BlankExperience' && (
    <Page title={title} dividerLabel="Experience" backHref="/">
      <CategoryGrid items={childItems} />
    </Page>
  )}

  {!pageType && page && (
    <pre>{JSON.stringify(page, null, 2)}</pre>
  )}

</Layout>

<script is:inline src="https://app-epsamoeydevva227p001.cms.optimizely.com/util/javascript/communicationinjector.js"></script>

<script>
  window.addEventListener('optimizely:cms:contentSaved', (event: Event) => {
    const message = (event as CustomEvent).detail as {
      previewToken?: string;
      contentLink?: string;
    };

    const newToken = message?.previewToken;
    if (!newToken) return;

    const url = new URL(window.location.href);
    url.searchParams.set('preview_token', newToken);
    window.location.href = url.toString();
  });
</script>
