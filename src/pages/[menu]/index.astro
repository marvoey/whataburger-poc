---
import Layout from '@layouts/Layout.astro';
import Page from '@components/Page.astro';
import CategoryGrid from '@components/CategoryGrid.astro';
import { GraphClient } from '@optimizely/cms-sdk';

const cmsClient = new GraphClient(import.meta.env.OPTIMIZELY_GRAPH_SINGLE_KEY, {
  graphUrl: `${import.meta.env.OPTIMIZELY_GRAPH_GATEWAY}/content/v2`,
});

const { menu } = Astro.params;

// --- Domain resolution ---
const CMS_ORIGIN = import.meta.env.CMS_ORIGIN as string | undefined;
const DOMAIN_ALIASES = import.meta.env.DOMAIN_ALIASES as string | undefined;
const aliases = new Set((DOMAIN_ALIASES ?? '').split(',').map((s) => s.trim()).filter(Boolean));
const base = CMS_ORIGIN && aliases.has(Astro.url.host) ? CMS_ORIGIN : Astro.url.origin;

const result = await cmsClient.request(`
  query MenuPageByPath($base: String!, $menu: String!) {
    _Page(
      where: {
        _metadata: {
          url: {
            base: { eq: $base }
            default: { eq: $menu }
          }
        }
      }
      limit: 1
    ) {
      items {
        _metadata {
          key
          displayName
          url { base default hierarchical }
        }
      }
    }
  }
`, { base, menu: `/${menu}/` });

const page = result?._Page?.items?.[0];
const pageHierarchical = page?._metadata?.url?.hierarchical;

const childrenResult = pageHierarchical ? await cmsClient.request(`
  query ChildPages($base: String!, $menu: String!) {
    WhataCategoryPage(
      where: {
        _metadata: {
          url: {
            base: { eq: $base }
            hierarchical: { startsWith: $menu, notEq: $menu }
          }
        }
      }
      orderBy: {
        _metadata: {
          sortOrder: ASC
        }
      }
    ) {
      items {
        _metadata {
          displayName
          url { default hierarchical }
        }
        Image {
          ... on ImageMedia {
            _assetMetadata {
              url
            }
          }
        }
      }
    }
  }
`, { base, menu: pageHierarchical }) : null;

type PageItem = { _metadata?: { displayName?: string; url?: { default?: string; hierarchical?: string } }; Image?: { _assetMetadata?: { url?: string } } };

const parentDepth = (pageHierarchical?.match(/\//g) ?? []).length;
const children = ((childrenResult?.WhataCategoryPage?.items ?? []) as PageItem[]).filter((item) => {
  const path = item._metadata?.url?.hierarchical ?? '';
  return (path.match(/\//g) ?? []).length === parentDepth + 1;
});

const menus = children.map((item) => {
  const name = item._metadata?.displayName ?? '';
  const slug = item._metadata?.url?.default;
  const image = item.Image?._assetMetadata?.url;
  return { name, slug, image };
});
---

<Layout>
  <Page title={page._metadata.displayName} dividerLabel="Categories" backHref="/">
    <CategoryGrid items={menus} />
    <div class="docs-link-wrap">
      <a class="docs-link" href="/content-model">Content Model Docs &rsaquo;</a>
    </div>
  </Page>
</Layout>

<style>
  .docs-link-wrap {
    max-width: 900px;
    margin: 32px auto 0;
    text-align: right;
  }

  .docs-link {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #888;
    text-decoration: none;
    text-transform: uppercase;
  }

  .docs-link:hover {
    color: #f47920;
  }
</style>
