---
import Layout from "@layouts/Layout.astro";
import Page from "@components/Page.astro";
import CustomizationGroups from "@components/CustomizationGroups.astro";
import { GraphClient } from "@optimizely/cms-sdk";

const { menu, category, item: itemSlug } = Astro.params;

const cmsClient = new GraphClient(import.meta.env.OPTIMIZELY_GRAPH_SINGLE_KEY, {
  graphUrl: `${import.meta.env.OPTIMIZELY_GRAPH_GATEWAY}/content/v2`,
});

const CMS_ORIGIN = import.meta.env.CMS_ORIGIN as string | undefined;
const DOMAIN_ALIASES = import.meta.env.DOMAIN_ALIASES as string | undefined;
const aliases = new Set(
  (DOMAIN_ALIASES ?? "")
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean),
);
const base =
  CMS_ORIGIN && aliases.has(Astro.url.host) ? CMS_ORIGIN : Astro.url.origin;

const result = await cmsClient.request(
  `
  query ItemPageByPath($base: String!, $path: String!) {
    WhataItemPage(
      where: {
        _metadata: {
          url: {
            base: { eq: $base }
            default: { eq: $path }
          }
        }
      }
      limit: 1
    ) {
      items {
        _metadata {
          displayName
          url { default hierarchical }
        }
        Image {
          ... on ImageMedia {
            _assetMetadata {
              url
            }
          }
        }
        CustomOptions {
          ... on WhataCustomOptionsGroup {
            _metadata { displayName }
            chooseOne
            Options {
              ... on WhataOption {
                _metadata { displayName }
                Calories
                addedCost
                Quantity
              }
            }
          }
        }
      }
    }
  }
`,
  { base, path: `/${menu}/${category}/${itemSlug}/` },
);

const page = result?.WhataItemPage?.items?.[0];
const itemName = page?._metadata?.displayName ?? itemSlug;

const groups = page?.CustomOptions ?? [];
---

<Layout>
  <Page title={itemName} dividerLabel={category ?? ''} backHref={`/${menu}/${category}`}>
    <div class="item-hero">
      <div class="hero-img-wrap">
        <img src={page?.Image?._assetMetadata?.url ?? '/images/Whataburger30.png'} alt={itemName} class="hero-img" />
      </div>
    </div>

    <CustomizationGroups groups={groups} />
  </Page>
</Layout>
