---
import Layout from '@layouts/Layout.astro';
import { loadCategories, visibleOptions } from '@lib/menu';
import { slugify } from '@lib/utils';

const { menu, item: itemSlug } = Astro.params;
const raw = loadCategories();
const cat = raw.find((c) => c.category === menu);
if (!cat) return Astro.redirect('/404');
const item = cat.items.find((i) => slugify(i.name) === itemSlug);
if (!item) return Astro.redirect('/404');
const { category } = cat;
---

<Layout>
  <div class="page">
    <header>
      <a class="back" href={`/${category}`}>&lsaquo; BACK</a>
      <span class="brand">WHATABURGER</span>
      <span class="spacer" />
    </header>

    <div class="content">
      <div class="item-hero">
        <div class="hero-img-wrap">
          <img src="/images/Whataburger30.png" alt={item.name} class="hero-img" />
        </div>
        <h1 class="page-title">{item.name}</h1>
      </div>

      {item.customizationGroups.map((group) => (
        <div class="group">
          <div class="group-header">
            <span class="group-name">{group.name}</span>
            <span class="group-type">{group.type}</span>
          </div>
          <ul class="options-list">
            {visibleOptions(group.options).map((opt) => (
              <li class="option-row">
                <div class={`option-control ${group.type}`} />
                <span class="option-name">{opt.displayName}</span>
                {opt.info && <span class="option-info">{opt.info}</span>}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .item-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 0 8px;
  }

  .hero-img-wrap {
    width: 180px;
    height: 135px;
    background: #ddd;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .group {
    max-width: 640px;
    margin: 0 auto 20px;
    background: #4a4a4a;
    border-radius: 8px;
    overflow: hidden;
  }

  .group-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: #555;
  }

  .group-name {
    color: #f0f0f0;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .group-type {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #f47920;
    background: rgba(244, 121, 32, 0.15);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .options-list {
    list-style: none;
    margin: 0;
    padding: 4px 0;
  }

  .option-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid #3d3d3d;
  }

  .option-row:last-child {
    border-bottom: none;
  }

  .option-control {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border: 2px solid #888;
    background: transparent;
  }

  .option-control.radio {
    border-radius: 50%;
  }

  .option-control.checkbox {
    border-radius: 3px;
  }

  .option-name {
    flex: 1;
    color: #e8e8e8;
    font-size: 0.9rem;
  }

  .option-info {
    color: #aaa;
    font-size: 0.8rem;
    white-space: nowrap;
  }
</style>
