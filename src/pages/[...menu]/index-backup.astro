---
import Layout from '../layouts/Layout.astro';
import { loadCategories } from '../lib/menu';
import { slugify, label } from '../lib/utils';

export function getStaticPaths() {
  const raw = loadCategories();

  return raw.map(({ category, items }) => ({
    params: { category },
    props: { items },
  }));
}

const { category } = Astro.params;
const { items } = Astro.props;
---

<Layout>
  <div class="page">
    <header>
      <a class="back" href="/">&lsaquo; BACK</a>
      <span class="brand">WHATABURGER</span>
      <span class="spacer" />
    </header>

    <div class="content">
      <h1 class="page-title">{label(category)}</h1>

      <ul class="category-grid">
        {items.map((item) => (
          <li>
            <a class="cat-card" href={`/${category}/${slugify(item.name)}`}>
              <div class="card-img-wrap">
                <img src="/images/Whataburger30.png" alt={item.name} class="card-img" />
              </div>
              <div class="caption">
                <h4>{item.name}</h4>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>
