---
import Layout from '@layouts/Layout.astro';
import Page from '@components/Page.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import ContentModelNav from '@components/ContentModelNav.astro';
---

<Layout>
  <Page title="WhataItemPage" dividerLabel="Content Type" backHref="/content-model">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Content Model', href: '/content-model' },
      { label: 'WhataItemPage' },
    ]} />
    <ContentModelNav current="whata-item-page" />

    <div class="doc-body">

      <section class="doc-section">
        <p class="doc-summary">
          A <strong>WhataItemPage</strong> represents an individual menu item
          (e.g. <em>Crispy Chicken Sandwich</em>, <em>Double Meat Whataburger</em>). It holds a
          product image and an array of <strong>WhataCustomOptionsGroup</strong> components that
          describe the available customizations.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Fields</h2>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>Image</code></td>
              <td>_IContent</td>
              <td>
                Product image. Resolved via <code>... on ImageMedia &#123; _assetMetadata &#123; url &#125; &#125;</code>.
                Falls back to <code>/images/Whataburger30.png</code> if absent.
              </td>
            </tr>
            <tr>
              <td><code>CustomOptions</code></td>
              <td>[_IContent]</td>
              <td>
                Ordered list of customization groups. Each item resolves as a
                <strong>WhataCustomOptionsGroup</strong> component.
              </td>
            </tr>
            <tr>
              <td><code>_metadata.displayName</code></td>
              <td>String</td>
              <td>The item name shown in the UI (e.g. <em>"Crispy Chicken Sandwich"</em>).</td>
            </tr>
            <tr>
              <td><code>_metadata.url.default</code></td>
              <td>String</td>
              <td>Short slug path (e.g. <code>/burgers/chicken/crispy-chicken-sandwich/</code>).</td>
            </tr>
            <tr>
              <td><code>_metadata.url.hierarchical</code></td>
              <td>String</td>
              <td>Full hierarchical path used by parent queries to scope children.</td>
            </tr>
            <tr>
              <td><code>_metadata.sortOrder</code></td>
              <td>Int</td>
              <td>Controls display order within the parent category page.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Embedded Component: WhataCustomOptionsGroup</h2>
        <p class="doc-note">
          Referenced via <code>CustomOptions</code>. Each group describes a set of choices the
          customer can make (e.g. <em>Size</em>, <em>Toppings</em>).
        </p>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>_metadata.displayName</code></td>
              <td>String</td>
              <td>Group label (e.g. <em>"Size"</em>, <em>"Toppings"</em>).</td>
            </tr>
            <tr>
              <td><code>chooseOne</code></td>
              <td>Boolean</td>
              <td><code>true</code> = radio button (select one); <code>false</code> = checkboxes (select many).</td>
            </tr>
            <tr>
              <td><code>Options</code></td>
              <td>[_IContent]</td>
              <td>Ordered list of <strong>WhataOption</strong> components.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Embedded Component: WhataOption</h2>
        <p class="doc-note">
          Referenced via <code>WhataCustomOptionsGroup.Options</code>. Represents one selectable choice.
        </p>
        <table class="doc-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Type</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>_metadata.displayName</code></td>
              <td>String</td>
              <td>Option label (e.g. <em>"Large"</em>, <em>"Add Jalapeños"</em>).</td>
            </tr>
            <tr>
              <td><code>Calories</code></td>
              <td>Int</td>
              <td>Calorie count for this option. Shown as <em>"XXX cal"</em>.</td>
            </tr>
            <tr>
              <td><code>addedCost</code></td>
              <td>Float</td>
              <td>Price modifier in dollars (e.g. <code>1.50</code>, <code>-0.50</code>, <code>0</code>). Shown as <em>"+$X.XX"</em>.</td>
            </tr>
            <tr>
              <td><code>Quantity</code></td>
              <td>Boolean</td>
              <td>Whether the customer can specify a quantity for this option.</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Relationships</h2>
        <div class="doc-rel-grid">
          <div class="doc-rel-card parent">
            <div class="doc-rel-label">Parent</div>
            <a class="doc-rel-type" href="/content-model/whata-category-page">WhataCategoryPage</a>
            <div class="doc-rel-desc">
              Belongs to one category. Queried by matching its hierarchical path using <code>startsWith</code>.
            </div>
          </div>
          <div class="doc-rel-card children">
            <div class="doc-rel-label">Embedded children</div>
            <div class="doc-rel-type">WhataCustomOptionsGroup</div>
            <div class="doc-rel-desc">
              Inline components stored in the <code>CustomOptions</code> content reference array.
              Each group contains <strong>WhataOption</strong> items.
            </div>
          </div>
        </div>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">URL Pattern</h2>
        <div class="doc-url-block">
          <span class="doc-url-route">Route file</span>
          <code>src/pages/[menu]/[category]/[item].astro</code>
          <span class="doc-url-route">URL</span>
          <code>/[menu]/[category]/[item]/</code>
          <span class="doc-url-route">Example</span>
          <code>/burgers/chicken/crispy-chicken-sandwich/</code>
        </div>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">GraphQL Query</h2>
        <pre class="doc-code"><code>{`query ItemPageByPath($base: String!, $path: String!) {
  WhataItemPage(
    where: {
      _metadata: {
        url: { base: { eq: $base }, default: { eq: $path } }
      }
    }
    limit: 1
  ) {
    items {
      _metadata {
        displayName
        url { default hierarchical }
      }
      Image {
        ... on ImageMedia {
          _assetMetadata { url }
        }
      }
      CustomOptions {
        ... on WhataCustomOptionsGroup {
          _metadata { displayName }
          chooseOne
          Options {
            ... on WhataOption {
              _metadata { displayName }
              Calories
              addedCost
              Quantity
            }
          }
        }
      }
    }
  }
}`}</code></pre>
      </section>

    </div>

  </Page>
</Layout>

<style>
  .doc-body {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .doc-summary {
    color: #ccc;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }

  .doc-summary strong { color: #f47920; }
  .doc-summary a { color: #7abfe8; text-decoration: none; }
  .doc-summary a:hover { text-decoration: underline; }

  .doc-note {
    color: #bbb;
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .doc-note code { color: #e8c47a; font-size: 0.82rem; }
  .doc-note strong { color: #f47920; }

  .doc-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .doc-section-title {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #aaa;
  }

  .doc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    background: #2a2a2a;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #444;
  }

  .doc-table th {
    background: #333;
    color: #ccc;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 14px;
    text-align: left;
  }

  .doc-table td {
    padding: 10px 14px;
    color: #ccc;
    border-top: 1px solid #3a3a3a;
    vertical-align: top;
    line-height: 1.5;
  }

  .doc-table td:first-child { white-space: nowrap; }

  .doc-table code {
    color: #e8c47a;
    font-size: 0.82rem;
  }

  .doc-table em { color: #999; font-style: italic; }
  .doc-table strong { color: #f47920; }

  .doc-rel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .doc-rel-card {
    background: #2a2a2a;
    border: 1px solid #444;
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .doc-rel-card.parent { border-left: 3px solid #7abfe8; }
  .doc-rel-card.children { border-left: 3px solid #888; }

  .doc-rel-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
  }

  .doc-rel-type {
    font-family: monospace;
    font-size: 0.9rem;
    font-weight: 700;
    color: #f47920;
    text-decoration: none;
  }

  a.doc-rel-type:hover { text-decoration: underline; }

  .doc-rel-desc {
    font-size: 0.8rem;
    color: #999;
    line-height: 1.5;
  }

  .doc-rel-desc code { color: #e8c47a; font-size: 0.78rem; }
  .doc-rel-desc strong { color: #f47920; }

  .doc-url-block {
    background: #2a2a2a;
    border: 1px solid #444;
    border-radius: 8px;
    padding: 14px 16px;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 6px 16px;
    align-items: center;
    font-size: 0.85rem;
  }

  .doc-url-route {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
  }

  .doc-url-block code {
    color: #7abfe8;
    font-size: 0.85rem;
  }

  .doc-code {
    margin: 0;
    background: #1e1e1e;
    border: 1px solid #444;
    border-radius: 8px;
    padding: 16px 18px;
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.6;
    color: #ccc;
  }

  .doc-code code { font-family: monospace; }

  @media (max-width: 600px) {
    .doc-rel-grid { grid-template-columns: 1fr; }
    .doc-url-block { grid-template-columns: 1fr; }
  }
</style>
