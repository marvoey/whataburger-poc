---
import Layout from '../layouts/Layout.astro';
import type { MenuPage } from '../types/MenuPage';
import { loadCategories } from '../lib/menu';
import { slugify, label } from '../lib/utils';

// ---------------------------------------------------------------------------
// Data source — raw categories JSON mapped into MenuPage.
// When a real GraphQL endpoint is available, replace this block with a query
// and the template below stays untouched.
// ---------------------------------------------------------------------------

const raw = loadCategories();

const page: MenuPage = {
  Title: 'Categories',
  Categories: raw.map(({ category }) => ({
    Name: label(category),
    Asset: {
      __typename: 'ContentReference',
      url: { __typename: 'ContentUrl', default: '/images/Whataburger30.png' },
    },
  })),
};
---

<Layout>
  <div class="page">
    <header>
      <span class="back">&lsaquo; BACK</span>
      <span class="brand">WHATABURGER</span>
      <span class="spacer" />
    </header>

    <div class="content">
      <h1 class="page-title">{page.Title}</h1>

      <div class="section-divider">
        <span class="divider-line" />
        <span class="divider-text">{page.Title}</span>
        <span class="divider-line" />
      </div>

      <ul class="category-grid">
        {page.Categories.map((cat) => (
          <li>
            <a class="cat-card" href={slugify(cat.Name)}>
              <div class="card-img-wrap">
                <img src={cat.Asset.url?.default ?? ''} alt={cat.Name} class="card-img" />
              </div>
              <div class="caption">
                <h4>{cat.Name}</h4>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>
