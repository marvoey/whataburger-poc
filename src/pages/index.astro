---
import Layout from '@layouts/Layout.astro';
import Page from '@components/Page.astro';
import CategoryGrid from '@components/CategoryGrid.astro';
import { GraphClient } from '@optimizely/cms-sdk';

const cmsClient = new GraphClient(import.meta.env.OPTIMIZELY_GRAPH_SINGLE_KEY, {
  graphUrl: `${import.meta.env.OPTIMIZELY_GRAPH_GATEWAY}/content/v2`,
});

// --- Domain resolution ---
const CMS_ORIGIN = import.meta.env.CMS_ORIGIN as string | undefined;
const DOMAIN_ALIASES = import.meta.env.DOMAIN_ALIASES as string | undefined;
const aliases = new Set((DOMAIN_ALIASES ?? '').split(',').map((s) => s.trim()).filter(Boolean));
const base = CMS_ORIGIN && aliases.has(Astro.url.host) ? CMS_ORIGIN : Astro.url.origin;

const result = await cmsClient.request(`
  query HomePageByPath($base: String!) {
    _Page(
      where: {
        _metadata: {
          url: {
            base: { eq: $base }
            default: { eq: "/" }
          }
        }
      }
      limit: 1
    ) {
      items {
        _metadata {
          key
          displayName
          url { base default }
        }
      }
    }
  }
`, { base });

const page = result?._Page?.items?.[0];

const childrenResult = await cmsClient.request(`
  query ChildPages($base: String!) {
    _Page(
      where: {
        _metadata: {
          url: {
            base: { eq: $base }
            
          }
        }
      }
      orderBy: {                                                                                              
        _metadata: {
          sortOrder: ASC
        }
      }
    ) {
      items {
        _metadata {
          displayName
          url { base default hierarchical }
        }
      }
    }
  }
`, { base });

type PageItem = { _metadata?: { displayName?: string; url?: { default?: string; hierarchical?: string } } };

const children = ((childrenResult?._Page?.items ?? []) as PageItem[]).filter((item) => {
  const path = item._metadata?.url?.hierarchical ?? '';
  return (path.match(/\//g) ?? []).length === 2;
});

const menus = children.map((item) => {
  const name = item._metadata?.displayName ?? '';
  const slug = item._metadata?.url?.default;
  return { name, slug };
});
---

<Layout>
  <Page title="Menus" dividerLabel="Menus">
    <CategoryGrid items={menus} />
  </Page>
</Layout>
