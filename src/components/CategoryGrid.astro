---
interface Props {
  items: { name: string; slug?: string | null; image?: string | null }[];
}

const { items } = Astro.props;
---

<ul class="category-grid">
  {items.map((item) => (
    <li>
      <a class="cat-card" href={item.slug}>
        <div class="card-img-wrap">
          <img src={item.image ?? `https://picsum.photos/seed/${encodeURIComponent(item.name)}/400/300`} alt={item.name} class="card-img" />
        </div>
        <div class="caption">
          <h4>{item.name}</h4>
        </div>
      </a>
    </li>
  ))}
</ul>
