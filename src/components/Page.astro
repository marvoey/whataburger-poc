---
interface Props {
  title: string;
  dividerLabel: string;
  backHref?: string;
}

const { title, dividerLabel, backHref } = Astro.props;
---

<div class="page">
  <header>
    <a class="brand" href="/"><img src="https://whataburger.com/assets/images/navigation/whataburger-footer-logo.png" alt="Whataburger" /></a>
    <span class="spacer" />
    {backHref ? (
      <a class="back" href={backHref}>&lsaquo; BACK</a>
    ) : (
      <span class="back">&lsaquo; BACK</span>
    )}
  </header>

  <div class="content">
    <h1 class="page-title">{title}</h1>

    <div class="section-divider">
      <span class="divider-line" />
      <span class="divider-text">{dividerLabel}</span>
      <span class="divider-line" />
    </div>

    <slot />
  </div>
</div>
